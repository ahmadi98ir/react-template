{
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".",
    "args": {
      "NEXT_PUBLIC_API_URL": "https://ahmadi98.ir"
    },
    "git": {
      "url": "https://github.com/ahmadi98ir/react-template.git",
      "branch": "main"
    }
  },
  "deploy": {
    "image": "ghcr.io/ahmadi98ir/react-template:${COOLIFY_RESOURCE_UUID}",
    "ports": ["3000"],
    "environment": {
      "NODE_ENV": "production",
      "NEXT_PUBLIC_API_URL": "https://ahmadi98.ir"
    },
    "registry": {
      "url": "ghcr.io",
      "username": "${GITHUB_USERNAME}",
      "password": "${GITHUB_TOKEN}"
    }
  }
} 