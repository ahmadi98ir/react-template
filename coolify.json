{
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".",
    "args": {
      "NEXT_PUBLIC_API_URL": "https://ahmadi98.ir"
    }
  },
  "deploy": {
    "image": "coolify/${COOLIFY_RESOURCE_UUID}",
    "ports": ["3000"],
    "environment": {
      "NODE_ENV": "production",
      "NEXT_PUBLIC_API_URL": "https://ahmadi98.ir",
      "POSTGRES_USER": "postgres",
      "POSTGRES_PASSWORD": "postgres",
      "POSTGRES_DB": "ahmadi98",
      "DATABASE_URL": "postgresql://postgres:postgres@postgres:5432/ahmadi98"
    },
    "healthcheck": {
      "path": "/api/health",
      "interval": "30s",
      "timeout": "10s",
      "retries": 3
    }
  },
  "git": {
    "repository": "https://github.com/ahmadi98ir/react-template.git",
    "branch": "main"
  }
} 