{
  "name": "ahmadi98",
  "version": "3.8.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "13.5.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "next-auth": "4.23.2",
    "@prisma/client": "5.4.2",
    "axios": "1.5.1",
    "sass": "1.69.0",
    "react-bootstrap": "^2.10.1",
    "react-countup": "^6.5.0",
    "react-visibility-sensor": "^5.1.1",
    "bootstrap": "^5.3.2"
  },
  "devDependencies": {
    "eslint": "8.51.0",
    "eslint-config-next": "13.5.4",
    "prisma": "5.4.2",
    "@types/node": "20.8.4",
    "@types/react": "18.2.28"
  },
  "env": {
    "NEXTAUTH_URL": "${NEXTAUTH_URL}",
    "NEXTAUTH_SECRET": "${NEXTAUTH_SECRET}",
    "DATABASE_URL": "${DATABASE_URL}"
  },
  "services": {
    "web": {
      "build": ".",
      "ports": [
        "3000:3000"
      ],
      "environment": {
        "DATABASE_URL": "${DATABASE_URL}",
        "NEXTAUTH_URL": "${NEXTAUTH_URL}",
        "NEXTAUTH_SECRET": "${NEXTAUTH_SECRET}"
      },
      "restart": "always"
    }
  }
}
